new file mode 100644
index 0000000..bbcf075
--- /dev/null
+++ b/src/retry.py
@@ -0,0 +1,12 @@
+import time
+
+
+def with_retry(fn, attempts: int = 10):
+    """Call fn, retrying on any exception."""
+    for i in range(attempts):
+        try:
+            return fn()
+        except Exception:
+            if i == attempts - 1:
+                raise
+            time.sleep(1)
